{
  "extends": "expo/tsconfig.base",

  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",

    "jsx": "react-jsx",

    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "strict": true,
    "isolatedModules": true,
    "noEmit": true,

    "skipLibCheck": true,

    "allowJs": true,
    "types": ["react", "react-native"]
  },

  "include": [
    "App.tsx",
    "src/**/*"
  ],

  "exclude": [
    "node_modules"
  ]
}